# Postgres credentials — shared by the db container and the API/poller connection string.
POSTGRES_USER=applytrack
POSTGRES_PASSWORD=applytrack
POSTGRES_DB=applytrack

# Migration timeout in seconds (default 60). Increase for slower databases / many
# migrations; the same timeout applies to every script the run executes.
# MigrationTimeoutSeconds=120

# Host port the API container publishes (container always listens on 8080 internally).
# Guard rail: compose runs a preflight that REFUSES to start the api when something
# already listens on this port (8080 is contested — vLLM, llama.cpp, dev tools all
# default to it). Relocate here instead of binding over a neighbour.
API_PORT=8080

# Optional: override the API connection string directly (e.g. pointing at an
# external Postgres). When unset, the compose default / appsettings.json is used.
# ConnectionStrings__Postgres=Host=localhost;Port=5432;Database=applytrack;Username=applytrack;Password=applytrack

# Poller cadence (seconds). The poller container drains the on-demand poll queue every
# DRAIN_INTERVAL and runs a full multi-tenant poll every POLL_INTERVAL.
# DRAIN_INTERVAL=60
# POLL_INTERVAL=3600

# Optional: override the poller's connection directly (libpq URL). When unset, the
# compose default points it at the bundled db service.
# DATABASE_URL=postgresql://applytrack:applytrack@localhost:5432/applytrack

# --- Cover-letter AI (optional) ---------------------------------------------
# Instance-wide default LLM endpoint for cover-letter drafting. Any tenant can
# override these in the SPA's AI panel; if neither is set, drafting is simply off
# until a tenant configures their own. Point BaseUrl at any OpenAI-compatible
# server — a local Ollama/vLLM keeps résumé data on-prem at $0/draft.
# Llm__BaseUrl=http://localhost:11434/v1
# Llm__Model=llama3.1:8b
# Llm__ApiKey=                       # only needed for hosted providers (OpenAI, etc.)

# Master key for encrypting per-tenant API keys at rest (AES-256-GCM). Set this to
# a long random string in any deployment where tenants store their own keys; without
# it the per-tenant key field is disabled (the instance default still works).
# APPLYTRACK_SECRETS_KEY=change-me-to-a-long-random-secret
